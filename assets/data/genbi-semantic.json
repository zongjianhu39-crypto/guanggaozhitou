{
  "version": "2026-04-10",
  "docsSource": "docs/current/报表字段及关系-标准文档.md",
  "defaults": {
    "primaryRoiMetric": "breakeven_roi",
    "fallbackEfficiencyMetricForCrowdAndSingle": "order_cost",
    "timezone": "Asia/Shanghai"
  },
  "rag": {
    "enabled": true,
    "maxReferences": 5,
    "sources": {
      "rulesDocs": {
        "enabled": true,
        "docs": [
          "docs/current/报表字段及关系-标准文档.md"
        ]
      },
      "promptTemplates": {
        "enabled": true,
        "limit": 6
      },
      "aiReports": {
        "enabled": true,
        "limit": 12
      },
      "aiPlaybooks": {
        "enabled": false,
        "limit": 0
      }
    }
  },
  "ruleVersions": {
    "crowdBudget": "v1",
    "crowdMix": "v1",
    "dailyDropReason": "v1",
    "weakProducts": "v1",
    "productPotential": "v1",
    "productSales": "v1",
    "periodicReport": "v1",
    "lossReason": "v1"
  },
  "intentRules": {
    "crowd_budget": "crowdBudget",
    "crowd_mix": "crowdMix",
    "daily_drop_reason": "dailyDropReason",
    "weak_products": "weakProducts",
    "product_potential": "productPotential",
    "product_sales": "productSales",
    "weekly_report": "periodicReport",
    "monthly_report": "periodicReport",
    "loss_reason": "lossReason"
  },
  "rules": {
    "crowdBudget": {
      "label": "人群预算建议",
      "version": "v1",
      "dataScope": ["crowd"],
      "strategy": {
        "metrics": ["order_cost", "crowd_cost_share", "ad_cost", "gmv", "orders"],
        "primaryMetric": "order_cost",
        "secondaryMetric": "crowd_cost_share",
        "increaseSort": "primary_asc",
        "decreaseSort": "primary_desc"
      },
      "filters": {
        "minCostShare": 0.05,
        "excludeLayers": ["未知"],
        "requireFinitePrimaryMetric": true
      },
      "output": {
        "topIncreaseCount": 3,
        "topDecreaseCount": 3,
        "tableLimit": 10,
        "columns": ["人群分层", "花费", "花费占比", "订单成本", "成交金额", "成交笔数"]
      }
    },
    "crowdMix": {
      "label": "老客新客结构分析",
      "version": "v1",
      "dataScope": ["crowd"],
      "strategy": {
        "metrics": ["crowd_cost_share", "order_cost", "ad_cost"],
        "primaryMetric": "crowd_cost_share",
        "comparisonLayers": ["老客", "新客", "兴趣新客"]
      },
      "output": {
        "columns": ["人群分层", "花费", "花费占比", "订单成本"]
      }
    },
    "dailyDropReason": {
      "label": "昨日花费波动归因",
      "version": "v1",
      "dataScope": ["crowd"],
      "strategy": {
        "metrics": ["ad_cost"],
        "primaryMetric": "ad_cost",
        "comparisonMode": "current_vs_previous"
      },
      "output": {
        "topDropCount": 3,
        "columns": ["人群分层", "昨日花费", "前一日花费", "变化额"]
      }
    },
    "weakProducts": {
      "label": "高花费低回报商品",
      "version": "v1",
      "dataScope": ["single"],
      "strategy": {
        "metrics": ["product_direct_roi", "order_cost", "ad_cost", "product_direct_gmv", "product_orders"],
        "primaryMetric": "product_direct_roi",
        "secondaryMetric": "order_cost",
        "sort": ["primary_asc", "secondary_desc", "cost_desc"]
      },
      "filters": {
        "minFocusPoolSize": 20,
        "focusPoolCostCoverage": 0.85,
        "requirePositiveCost": true
      },
      "output": {
        "topCount": 8,
        "highlightCount": 3,
        "columns": ["商品", "花费", "商品订单成本", "商品直接ROI", "商品直接成交金额", "商品直接成交笔数"]
      }
    },
    "productPotential": {
      "label": "冲销售额商品识别",
      "version": "v1",
      "dataScope": ["single"],
      "strategy": {
        "metrics": ["product_direct_roi", "product_direct_gmv", "order_cost", "ad_cost"],
        "primaryMetric": "product_direct_roi",
        "secondaryMetric": "product_direct_gmv",
        "sort": ["roi_x_gmv_desc"]
      },
      "filters": {
        "requirePositiveCost": true,
        "requirePositiveOrders": true
      },
      "output": {
        "topCount": 6,
        "highlightCount": 3,
        "columns": ["商品", "花费", "商品直接ROI", "商品直接成交金额", "商品订单成本"]
      }
    },
    "productSales": {
      "label": "单商品销售查询",
      "version": "v1",
      "dataScope": ["single"],
      "strategy": {
        "metrics": ["ad_cost", "product_direct_gmv", "product_orders", "product_direct_roi", "order_cost"],
        "matchMode": "product_name_contains"
      },
      "output": {
        "resultLimit": 1,
        "columns": ["商品", "花费", "商品直接成交金额", "商品直接成交笔数", "商品直接ROI", "商品订单成本"]
      }
    },
    "periodicReport": {
      "label": "周期报告",
      "version": "v1",
      "dataScope": ["ads", "crowd", "single"],
      "strategy": {
        "metrics": ["breakeven_roi", "ad_cost", "order_cost", "product_direct_gmv", "product_direct_roi", "wow", "mom"],
        "primaryMetric": "breakeven_roi",
        "secondaryMetric": "wow_or_mom"
      },
      "output": {
        "topCrowdCount": 5,
        "topProductCount": 5,
        "columns": ["指标", "当前周期", "上一周期", "周环比", "月环比", "人群分层", "花费", "订单成本", "商品", "商品直接成交金额", "商品直接ROI"]
      }
    },
    "lossReason": {
      "label": "亏损原因分析",
      "version": "v1",
      "dataScope": ["ads", "crowd", "single"],
      "strategy": {
        "metrics": ["breakeven_roi", "ad_cost", "gmv", "order_cost"],
        "primaryMetric": "breakeven_roi",
        "crowdSort": "order_cost_desc",
        "productSort": "order_cost_desc"
      },
      "output": {
        "topCrowdCount": 3,
        "topProductCount": 3,
        "columns": ["指标", "数值", "人群分层", "订单成本", "商品", "商品订单成本"]
      }
    }
  },
  "sources": {
    "financial": {
      "label": "财务报表",
      "grain": [
        "day",
        "week",
        "month"
      ],
      "primaryDateField": "日期",
      "expandable": true
    },
    "single_product_ad": {
      "label": "单品广告",
      "grain": [
        "day",
        "week",
        "month"
      ],
      "primaryDateField": "日期",
      "expandable": true
    },
    "taobao_live": {
      "label": "淘宝直播",
      "grain": [
        "day",
        "week",
        "month"
      ],
      "primaryDateField": "日期",
      "expandable": true
    },
    "super_live": {
      "label": "超级直播",
      "grain": [
        "day",
        "week",
        "month"
      ],
      "primaryDateField": "日期",
      "expandable": true
    }
  },
  "dimensions": {
    "crowd_layer": {
      "label": "人群分层",
      "derivedFrom": "人群名字",
      "extensible": true
    },
    "plan_type": {
      "label": "计划分类",
      "derivedFrom": "计划名字",
      "extensible": true
    },
    "product_name": {
      "label": "商品名称"
    },
    "date": {
      "label": "日期"
    }
  },
  "metrics": {
    "breakeven_roi": {
      "label": "盈亏平衡ROI",
      "description": "默认 ROI 口径",
      "sourceScope": [
        "super_live",
        "financial",
        "taobao_live"
      ],
      "formula": "((保量佣金 + 预估结算线下佣金 + 预估结算机构佣金 - 直播间红包 - 严选红包) * (总成交笔数 / 成交笔数)) / 花费"
    },
    "order_cost": {
      "label": "订单成本",
      "description": "单品/人群无法计算盈亏平衡ROI时的默认效率指标",
      "sourceScope": [
        "super_live",
        "single_product_ad"
      ],
      "formula": "花费 / 成交笔数"
    },
    "direct_roi": {
      "label": "直接ROI",
      "formula": "直接成交金额 / 花费"
    },
    "ad_cost": {
      "label": "花费"
    },
    "gmv": {
      "label": "总成交金额"
    },
    "product_direct_gmv": {
      "label": "该商品直接成交金额"
    },
    "crowd_cost_share": {
      "label": "人群花费占比"
    },
    "wow": {
      "label": "周环比"
    },
    "product_direct_roi": {
      "label": "商品直接ROI",
      "formula": "该商品直接成交金额 / 花费"
    },
    "product_orders": {
      "label": "商品直接成交笔数"
    },
    "orders": {
      "label": "成交笔数"
    },
    "mom": {
      "label": "月环比"
    }
  },
  "intentGroups": [
    {
      "key": "crowd_budget",
      "label": "人群预算建议",
      "examples": [
        "哪些具体人群效果好需要增加预算，哪些人群差需要降低预算"
      ]
    },
    {
      "key": "weak_products",
      "label": "高花费低回报商品诊断",
      "examples": [
        "单品广告里哪些商品花费高但回报差"
      ]
    },
    {
      "key": "crowd_mix",
      "label": "老客新客结构分析",
      "examples": [
        "老客和新客的占比情况如何，是否合理"
      ]
    },
    {
      "key": "product_potential",
      "label": "冲销售额商品识别",
      "examples": [
        "哪些商品适合冲销售额"
      ]
    },
    {
      "key": "product_sales",
      "label": "单商品销售查询",
      "examples": [
        "某个商品近期的单品广告销售数据如何"
      ]
    },
    {
      "key": "weekly_report",
      "label": "周报生成",
      "examples": [
        "帮我整理一下上周的周报需要有近期周环比"
      ]
    },
    {
      "key": "monthly_report",
      "label": "月报生成",
      "examples": [
        "帮我整理一下上月的月报需要有近期月环比"
      ]
    },
    {
      "key": "daily_drop_reason",
      "label": "昨日花费波动归因",
      "examples": [
        "为什么昨日的花费下降了，在人群上有什么变化"
      ]
    },
    {
      "key": "loss_reason",
      "label": "亏损原因分析",
      "examples": [
        "为什么上周的花费盈亏ROI低于1是亏钱的，亏在了哪里"
      ]
    },
    {
      "key": "budget_plan",
      "label": "预算分配建议",
      "examples": [
        "如果本月还有100万预算，按照目前的情况接下来的费用该怎么花"
      ]
    }
  ]
}
